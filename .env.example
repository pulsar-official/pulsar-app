# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Database
DATABASE_URL=postgresql://user:password@host/database

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_key

# Typesense
NEXT_PUBLIC_TYPESENSE_HOST=host
NEXT_PUBLIC_TYPESENSE_PORT=443
NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your_api_key

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_BUCKET_NAME=pulsar-storage
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Clerk Webhook
CLERK_WEBHOOK_SECRET=whsec_

# Discord (feedback)
DISCORD_FEEDBACK_WEBHOOK_URL=

# Typesense Cloud (cloud.typesense.com — free tier)
# NEXT_PUBLIC_TYPESENSE_HOST=xxx.a1.typesense.net
# NEXT_PUBLIC_TYPESENSE_PORT=443
# NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
# TYPESENSE_API_KEY=your_api_key

# n8n (Railway — railway.app)
# N8N_WEBHOOK_URL=https://your-n8n.railway.app

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# QStash (Upstash message queue)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=eyJ...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# PowerSync
NEXT_PUBLIC_POWERSYNC_URL=https://yourinstance.powersync.journeyapps.com
POWERSYNC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
POWERSYNC_KEY_ID=pulsar-key-1
NEXT_PUBLIC_USE_POWERSYNC=false

# App
NEXT_PUBLIC_APP_URL=https://pulsar.zone